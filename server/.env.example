# La Passerelle — Configuration environnement
# Copier en .env et adapter les valeurs

# Port du serveur (défaut: 3717)
PORT=3717

# URL du client Vue (pour CORS)
CLIENT_URL=http://localhost:5173

# Secret JWT (CHANGER EN PRODUCTION !)
JWT_SECRET=passerelle-super-secret-change-this-in-prod

# Hash bcrypt du mot de passe de l'Amiral
# Générer avec : node -e "console.log(require('bcryptjs').hashSync('votre-mdp', 10))"
AMIRAL_PASSWORD_HASH=$2b$10$examplehashchangeme

# Bot Telegram dédié (Phase 4)
# TELEGRAM_BOT_TOKEN=your-bot-token-here
# TELEGRAM_CHAT_ID=your-chat-id-here

# Mode
NODE_ENV=development
